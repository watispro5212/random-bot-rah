{
  "manifest_version": 3,
  "name": "Insane Mod",
  "version": "1.0.0",
  "description": "Advanced MooMoo.io mod with bots, UI features, and combat automation.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["*://moomoo.io/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "extension/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://moomoo.io/*"],
      "css": ["menu.css"],
      "js": [
        "libs/jquery.min.js",
        "libs/msgpack.min.js",
        "libs/easystar.min.js",
        "menu.js",
        "mod.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
